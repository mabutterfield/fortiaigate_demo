aws_profile               = "AdministratorAccess-123456789012"
aws_region                = "us-east-1"
name_prefix               = "fortiaigate-demo"
ssh_key_name              = "my-existing-keypair"
ssh_private_key_file      = "~/.ssh/my-existing-keypair.pem"
allowed_ingress_cidr      = "203.0.113.10/32"
iam_instance_profile_name = "existing-ec2-ecr-readonly-profile"

# g4dn.xlarge is the default for cheaper infrastructure smoke tests.
# Use g4dn.4xlarge for full FortiAIGate validation.
instance_type = "g4dn.xlarge"


# g4dn uses Nvidia Tesla T4 GPU.  Works, but not officially supported
# g4dn.xlarge   4CPU/16GB <- smoke test linux install
# g4dn.2xlarge  8CPU/32GB <- meets min requirements
# g4dn.4xlarge  16CPU/64GB <- still below min requirements
# g4dn.8xlarge  32CPU/128GB <- meets recommend CPU/RAM



