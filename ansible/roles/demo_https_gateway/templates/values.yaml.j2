nameOverride: "{{ demo_https_gateway_release_name }}"

image:
  repository: "{{ demo_https_gateway_image_repository }}"
  tag: "{{ demo_https_gateway_image_tag }}"
  pullPolicy: "{{ demo_https_gateway_image_pull_policy }}"

resolver: "{{ demo_https_gateway_resolver }}"

tls:
  cert: |
{{ demo_https_gateway_cert_content | indent(4, true) }}
  key: |
{{ demo_https_gateway_key_content | indent(4, true) }}

routes:
{% for route in demo_https_gateway_routes %}
  - name: "{{ route.name }}"
    displayName: "{{ route.display_name | default(route.name) }}"
    externalPort: {{ route.external_port }}
    upstream: "{{ route.upstream }}"
{% endfor %}
