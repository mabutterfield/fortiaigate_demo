<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ demo_home_page_title }}</title>
  <style>
    :root {
      color-scheme: light;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #f6f7f9;
      color: #1f2933;
    }
    body {
      margin: 0;
      padding: 32px;
    }
    main {
      max-width: 1040px;
      margin: 0 auto;
    }
    h1 {
      margin: 0 0 8px;
      font-size: 30px;
      font-weight: 700;
    }
    .subtle {
      margin: 0 0 28px;
      color: #5c6670;
    }
    section {
      margin: 28px 0;
    }
    h2 {
      margin: 0 0 12px;
      font-size: 18px;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 12px;
    }
    a.card {
      display: block;
      padding: 14px 16px;
      border: 1px solid #d8dee4;
      border-radius: 6px;
      background: #ffffff;
      color: #1f2933;
      text-decoration: none;
    }
    a.card:hover {
      border-color: #2b6cb0;
    }
    .label {
      display: block;
      font-weight: 650;
      margin-bottom: 4px;
    }
    .url {
      display: block;
      color: #5c6670;
      font-size: 13px;
      overflow-wrap: anywhere;
    }
  </style>
</head>
<body>
  <main>
    <h1>{{ demo_home_page_title }}</h1>
    <p class="subtle">Direct model paths and FortiAIGate-inspected paths for this lab.</p>

    <section>
      <h2>FortiAIGate</h2>
      <div class="grid">
        <a class="card" href="{{ demo_home_fortiaigate_url }}">
          <span class="label">FortiAIGate UI</span>
          <span class="url">{{ demo_home_fortiaigate_url }}</span>
        </a>
      </div>
    </section>

    <section>
      <h2>LiteLLM</h2>
      <div class="grid">
{% for link in demo_home_litellm_links %}
        <a class="card" href="{{ link.url }}">
          <span class="label">{{ link.label }}</span>
          <span class="url">{{ link.url }}</span>
        </a>
{% endfor %}
      </div>
    </section>

    <section>
      <h2>Demo Home</h2>
      <div class="grid">
{% for link in demo_home_links %}
        <a class="card" href="{{ link.url }}">
          <span class="label">{{ link.label }}</span>
          <span class="url">{{ link.url }}</span>
        </a>
{% endfor %}
      </div>
    </section>

    <section>
      <h2>Open WebUI</h2>
      <div class="grid">
{% for link in demo_home_openwebui_links %}
        <a class="card" href="{{ link.url }}">
          <span class="label">{{ link.label }}</span>
          <span class="url">{{ link.url }}</span>
        </a>
{% endfor %}
      </div>
    </section>

    <section>
      <h2>Chatbots</h2>
      <div class="grid">
{% for link in demo_home_chatbot_links %}
        <a class="card" href="{{ link.url }}">
          <span class="label">{{ link.label }}</span>
          <span class="url">{{ link.url }}</span>
        </a>
{% endfor %}
      </div>
    </section>
  </main>
</body>
</html>
