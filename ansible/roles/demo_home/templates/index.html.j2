<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ demo_home_page_title }}</title>
  <style>
    :root {
      color-scheme: light;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #f6f7f9;
      color: #1f2933;
    }
    body {
      margin: 0;
      padding: 32px;
    }
    main {
      max-width: 1280px;
      margin: 0 auto;
    }
    h1 {
      margin: 0 0 8px;
      font-size: 30px;
      font-weight: 700;
    }
    .subtle {
      margin: 0 0 28px;
      color: #5c6670;
    }
    section {
      margin: 28px 0;
    }
    h2 {
      margin: 0 0 12px;
      font-size: 18px;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 12px;
    }
    .link-matrix {
      display: grid;
      grid-template-columns: repeat(4, minmax(180px, 1fr));
      gap: 12px;
      align-items: stretch;
    }
    .group-heading {
      padding: 0 2px 2px;
      color: #3d4852;
      font-size: 13px;
      font-weight: 700;
    }
    .group-heading.direct {
      grid-column: 1 / 3;
    }
    .group-heading.fortiweb {
      grid-column: 3 / 5;
      border-left: 2px solid #b8c2cc;
      padding-left: 14px;
    }
    .fortiweb-cell {
      border-left: 2px solid #b8c2cc;
      padding-left: 12px;
    }
    a.card {
      display: block;
      padding: 14px 16px;
      border: 1px solid #d8dee4;
      border-radius: 6px;
      background: #ffffff;
      color: #1f2933;
      text-decoration: none;
    }
    a.card:hover {
      border-color: #2b6cb0;
    }
    .label {
      display: block;
      font-weight: 650;
      margin-bottom: 4px;
    }
    .url {
      display: block;
      color: #5c6670;
      font-size: 13px;
      overflow-wrap: anywhere;
    }
    @media (max-width: 900px) {
      .link-matrix {
        grid-template-columns: repeat(2, minmax(180px, 1fr));
      }
      .group-heading.direct,
      .group-heading.fortiweb {
        grid-column: 1 / 3;
      }
      .group-heading.fortiweb,
      .fortiweb-cell {
        border-left: 0;
        padding-left: 0;
      }
      .group-heading.fortiweb {
        border-top: 2px solid #b8c2cc;
        padding-top: 12px;
      }
    }
  </style>
</head>
<body>
  <main>
    <h1>{{ demo_home_page_title }}</h1>
    <p class="subtle">Direct model paths and FortiAIGate-inspected paths for this lab.</p>

    <section>
      <h2>Fortinet Admin</h2>
      <div class="grid">
{% for link in demo_home_admin_links %}
        <a class="card" href="{{ link.url }}" target="_blank" rel="noopener noreferrer">
          <span class="label">{{ link.label }}</span>
          <span class="url">{{ link.url }}</span>
        </a>
{% endfor %}
      </div>
    </section>

    <section>
      <h2>LiteLLM</h2>
      <div class="link-matrix">
        <div class="group-heading direct">LiteLLM</div>
        <div class="group-heading fortiweb">LiteLLM Via FortiWeb</div>
{% for link in demo_home_litellm_links %}
{% if 'via FortiWeb' not in link.label %}
        <a class="card" href="{{ link.url }}" target="_blank" rel="noopener noreferrer">
          <span class="label">{{ link.label }}</span>
          <span class="url">{{ link.url }}</span>
        </a>
{% endif %}
{% endfor %}
{% for link in demo_home_litellm_links %}
{% if 'via FortiWeb' in link.label %}
        <div class="fortiweb-cell">
          <a class="card" href="{{ link.url }}" target="_blank" rel="noopener noreferrer">
            <span class="label">{{ link.label }}</span>
            <span class="url">{{ link.url }}</span>
          </a>
        </div>
{% endif %}
{% endfor %}
      </div>
    </section>

    <section>
      <h2>MCP Tools</h2>
      <div class="link-matrix">
        <div class="group-heading direct">MCP Tools</div>
        <div class="group-heading fortiweb">MCP Tools Via FortiWeb</div>
{% for link in demo_home_mcp_links %}
{% if 'via FortiWeb' not in link.label %}
        <a class="card" href="{{ link.url }}" target="_blank" rel="noopener noreferrer">
          <span class="label">{{ link.label }}</span>
          <span class="url">{{ link.url }}</span>
        </a>
{% endif %}
{% endfor %}
{% for link in demo_home_mcp_links %}
{% if 'via FortiWeb' in link.label %}
        <div class="fortiweb-cell">
          <a class="card" href="{{ link.url }}" target="_blank" rel="noopener noreferrer">
            <span class="label">{{ link.label }}</span>
            <span class="url">{{ link.url }}</span>
          </a>
        </div>
{% endif %}
{% endfor %}
      </div>
    </section>

    <section>
      <h2>Demo Home</h2>
      <div class="link-matrix">
        <div class="group-heading direct">Demo Home</div>
        <div class="group-heading fortiweb">Demo Home Via FortiWeb</div>
{% for link in demo_home_links %}
{% if 'via FortiWeb' not in link.label %}
        <a class="card" href="{{ link.url }}" target="_blank" rel="noopener noreferrer">
          <span class="label">{{ link.label }}</span>
          <span class="url">{{ link.url }}</span>
        </a>
{% endif %}
{% endfor %}
{% for link in demo_home_links %}
{% if 'via FortiWeb' in link.label %}
        <div class="fortiweb-cell">
          <a class="card" href="{{ link.url }}" target="_blank" rel="noopener noreferrer">
            <span class="label">{{ link.label }}</span>
            <span class="url">{{ link.url }}</span>
          </a>
        </div>
{% endif %}
{% endfor %}
      </div>
    </section>

{% if demo_home_openwebui_links | length > 0 %}
    <section>
      <h2>Open WebUI</h2>
      <div class="link-matrix">
        <div class="group-heading direct">Open WebUI</div>
        <div class="group-heading fortiweb">Open WebUI Via FortiWeb</div>
{% for link in demo_home_openwebui_links %}
{% if 'via FortiWeb' not in link.label %}
        <a class="card" href="{{ link.url }}" target="_blank" rel="noopener noreferrer">
          <span class="label">{{ link.label }}</span>
          <span class="url">{{ link.url }}</span>
        </a>
{% endif %}
{% endfor %}
{% for link in demo_home_openwebui_links %}
{% if 'via FortiWeb' in link.label %}
        <div class="fortiweb-cell">
          <a class="card" href="{{ link.url }}" target="_blank" rel="noopener noreferrer">
            <span class="label">{{ link.label }}</span>
            <span class="url">{{ link.url }}</span>
          </a>
        </div>
{% endif %}
{% endfor %}
      </div>
    </section>
{% endif %}

    <section>
      <h2>Chatbots</h2>
      <div class="link-matrix">
        <div class="group-heading direct">Chatbots</div>
        <div class="group-heading fortiweb">Chatbots Via FortiWeb</div>
{% for link in demo_home_chatbot_links %}
{% if 'via FortiWeb' not in link.label %}
        <a class="card" href="{{ link.url }}" target="_blank" rel="noopener noreferrer">
          <span class="label">{{ link.label }}</span>
          <span class="url">{{ link.url }}</span>
        </a>
{% endif %}
{% endfor %}
{% for link in demo_home_chatbot_links %}
{% if 'via FortiWeb' in link.label %}
        <div class="fortiweb-cell">
          <a class="card" href="{{ link.url }}" target="_blank" rel="noopener noreferrer">
            <span class="label">{{ link.label }}</span>
            <span class="url">{{ link.url }}</span>
          </a>
        </div>
{% endif %}
{% endfor %}
      </div>
    </section>
  </main>
</body>
</html>
