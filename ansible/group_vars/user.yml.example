# Optional Phase 6 appliance traffic-path source of truth. This is data only
# until the FortiGate/FortiWeb config roles consume it.
# fortinet_traffic_paths:
#   - name: chatbot_to_fortigate_to_fortiaigate
#     enabled: true
#     ingress_appliance: fortigate
#     source_service: chatbot
#     target_service: fortiaigate
#     mode: proxy_nat
#   - name: chatbot_to_fortiweb_to_mcp
#     enabled: true
#     ingress_appliance: fortiweb
