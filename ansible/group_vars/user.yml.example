---
# Copy this file to ansible/group_vars/user.yml and personalize only values
# specific to your workstation, AWS account, licenses, credentials, or local
# preferences.
#
# Repo-owned defaults live in tracked ansible/group_vars/system.yml. Avoid
# copying system defaults here unless you intentionally want to pin an override.

# AWS profile/region normally come from Terraform-generated group vars after
# terraform/aws-ec2-k3s applies. Set these only for local-only Ansible runs or
# when bypassing Terraform.
# aws_profile: AdministratorAccess-123456789012
# aws_region: us-east-1

# Override only when the repo is not under the default parent FAIG directory.
# faig_workspace_root: /path/to/FAIG

# FortiAIGate licenses are local/private and must not be committed.
license_source_dir: "{{ faig_workspace_root }}/licenses"
fortiaigate_license_files:
  - License1.lic

# Optional explicit node-to-license map. Replace the key with the Kubernetes
# node name only when the default single-node mapping is not enough.
fortiaigate_licenses: {}
# fortiaigate_licenses:
#   ip-10-42-1-10.ec2.internal: License1.lic

# Optional FortiGate application API accounts. Keep real API keys only in
# ignored ansible/group_vars/user.yml or another private vars file.
# fortigate_api_accounts:
#   - name: faig-mcp-readonly
#     accprofile: super_admin
#     api_key: replace-with-private-token
#     trusthost:
#       - id: 1
#         type: ipv4-trusthost
#         ipv4_trusthost: "10.20.0.0 255.255.0.0"
# fortigate_readonly_accprofile_name: FAIG_READ_ONLY
# fortigate_readonly_api_account_enabled: true
# fortigate_readonly_api_account_name: faig-readonly-api
# fortigate_readonly_api_account_rotate_token: false
# fortigate_bootstrap_api_account_manage_trusthost: true
# fortigate_bootstrap_api_account_trusthost_cidrs:
#   - "199.45.245.116/32"
# fortigate_readonly_api_account_trusthost_cidrs:
#   - "199.45.245.116/32"
# fortigate_readonly_api_account_include_vpc_cidr: true
# fortigate_api_accounts_secret_file: "{{ playbook_dir }}/../secrets/fortigate_api.generated.yml"

# Optional FortiGate system/configuration overrides used by
