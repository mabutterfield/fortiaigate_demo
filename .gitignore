# Local .terraform directories
.terraform/

# OS and filesystem noise
.DS_Store
._*
.Spotlight-V100/
.Trashes/
ehthumbs.db
Thumbs.db
Desktop.ini

# Editor swap and backup files
*~
*.swp
*.swo

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Optional: ignore graph output files generated by `terraform graph`
# *.dot

# Optional: ignore plan files saved before destroying Terraform configuration
# Uncomment the line below if you want to ignore planout files.
# planout

# Terraform variable and plan artifacts
*.auto.tfvars
!terraform/*/00-system.auto.tfvars
!terraform/*/50-user.auto.tfvars
!terraform/*/99-local.auto.tfvars.example
*.tfplan
tfplan

# Python generated files
__pycache__/
*.py[cod]
*$py.class

# Ansible local, generated, and secret-bearing files
*.retry
ansible/group_vars/all.yml
ansible/group_vars/env.yml
ansible/group_vars/user.yml
ansible/host_vars/*.yml
!ansible/group_vars/*.example.yml
!ansible/group_vars/*.yml.example
!ansible/host_vars/*.example.yml
ansible/inventory/aws.generated.ini
ansible/inventory/fortigate.generated.ini
ansible/inventory/fortiweb.generated.ini
ansible/secrets/
ansible/group_vars/ecr.generated.yml
ansible/group_vars/bedrock.generated.yml
ansible/group_vars/fortiweb.generated.yml
ansible/group_vars/ports.generated.yml
ansible/group_vars/terraform.generated.yml
ansible/group_vars/images.yml

# Operator-owned mutable instruction profiles
chatbot/instructions/local/

# Operator-owned local document fixtures
mcp/documents/local/

# Kubernetes and deployment generated files
*.kubeconfig
kubeconfig
rendered.yaml
rendered*.yaml

# Secrets and private material
*.pem
*.key
*.crt
*.p12
*.lic
.env
.env.*

# Image archives and publishing outputs
*.tgz
*.tar
*.tar.gz
loaded-images.txt
published-images.txt
